{
  "manifest_version": 3,
  "name": "Twitch Music Panel",
  "version": "1.0.0",
  "description": "Ajoute un bouton flottant sur Twitch pour afficher/masquer un lecteur de musique intégré.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*",
    "https://open.spotify.com/*",
    "https://*.spotify.com/*"
  ],
  "action": {
    "default_title": "Twitch Music Panel"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.twitch.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://open.spotify.com/*",
        "https://*.spotify.com/*"
      ],
      "js": [
        "spotify-volume-main.js"
      ],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://open.spotify.com/*",
        "https://*.spotify.com/*"
      ],
      "js": [
        "spotify-volume.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
